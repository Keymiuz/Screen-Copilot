{
  "name": "screenmind",
  "version": "0.1.0",
  "description": "A cloud-powered screen-aware AI copilot for desktop.",
  "main": "out/main/main.js",
  "private": true,
  "author": "ScreenMind",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.screenmind.app",
    "productName": "ScreenMind",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "sharp": "^0.34.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
